};
service : (CyclesBillingConfig) -> {
  append_node : (AppendNodeRequest) -> (Result);
  authorize_ops_answer_session : (OpsAnswerSessionRequest) -> (Result_1);
  authorize_url_ingest_trigger_session : (UrlIngestTriggerSessionRequest) -> (
      Result_1,
    );
  begin_database_archive : (text) -> (Result_2);
  begin_database_restore : (text, blob, nat64) -> (Result_1);
  cancel_database_archive : (text) -> (Result_1);
  cancel_database_restore : (text) -> (Result_1);
  canister_health : () -> (CanisterHealth) query;
  check_cycles_top_up : () -> (Result_3);
  check_database_write_cycles : (text) -> (Result_1) query;
  check_ops_answer_session : (OpsAnswerSessionRequest) -> (Result_4) query;
  check_source_run_session : (SourceRunSessionCheckRequest) -> (Result_1) query;
  check_url_ingest_trigger_session : (UrlIngestTriggerSessionCheckRequest) -> (
      Result_1,
    ) query;
  create_database : (CreateDatabaseRequest) -> (Result_5);
  delete_database : (DeleteDatabaseRequest) -> (Result_1);
  delete_node : (DeleteNodeRequest) -> (Result_6);
  edit_node : (EditNodeRequest) -> (Result_7);
  export_snapshot : (ExportSnapshotRequest) -> (Result_8) query;
  fetch_updates : (FetchUpdatesRequest) -> (Result_9) query;
  finalize_database_archive : (text, blob) -> (Result_1);
  finalize_database_restore : (text) -> (Result_1);
  get_cycles_billing_config : () -> (Result_10) query;
  glob_nodes : (GlobNodesRequest) -> (Result_11) query;
  grant_database_access : (text, text, DatabaseRole) -> (Result_1);
  graph_links : (GraphLinksRequest) -> (Result_12) query;
  graph_neighborhood : (GraphNeighborhoodRequest) -> (Result_12) query;
  http_request : (HttpRequest) -> (HttpResponse) query;
  icrc10_supported_standards : () -> (vec Icrc10SupportedStandard) query;
  icrc21_canister_call_consent_message : (Icrc21ConsentMessageRequest) -> (
      Icrc21ConsentMessageResponse,
    );
  incoming_links : (IncomingLinksRequest) -> (Result_12) query;
  list_children : (ListChildrenRequest) -> (Result_13) query;
  list_database_cycle_entries : (text, opt nat64, nat32) -> (Result_14) query;
  list_database_cycles_pending_purchases : (text) -> (Result_15) query;
  list_database_members : (text) -> (Result_16) query;
  list_databases : () -> (Result_17) query;
  list_nodes : (ListNodesRequest) -> (Result_18) query;
  market_count_active_entitlements : (text) -> (Result_19) query;
  market_create_listing : (MarketCreateListingRequest) -> (Result_20);
  market_get_listing : (text) -> (Result_21) query;
  market_list_database_entitlements : (text, opt text, nat32) -> (
      Result_22,
    ) query;
  market_list_database_listings : (text) -> (Result_23) query;
  market_list_entitlements : (opt text, nat32) -> (Result_22) query;
  market_list_listings : (opt text, nat32) -> (Result_24) query;
  market_list_orders : (opt text, nat32) -> (Result_25) query;
  market_list_seller_listings : (text, opt text, nat32) -> (Result_24) query;
  market_pause_listing : (text) -> (Result_20);
  market_preview_purchase : (text) -> (Result_26) query;
  market_publish_listing : (text) -> (Result_20);
  market_purchase_access : (MarketPurchaseRequest) -> (Result_27);
  market_update_listing : (MarketUpdateListingRequest) -> (Result_20);
  memory_manifest : () -> (MemoryManifest) query;
  mkdir_node : (MkdirNodeRequest) -> (Result_28);
  move_node : (MoveNodeRequest) -> (Result_29);
  multi_edit_node : (MultiEditNodeRequest) -> (Result_7);
  outgoing_links : (OutgoingLinksRequest) -> (Result_12) query;
  purchase_database_cycles : (DatabaseCyclesPurchaseRequest) -> (Result_30);
  query_context : (QueryContextRequest) -> (Result_31) query;
  query_database_sql_json : (text, text, nat32) -> (Result_32) query;
  query_index_sql_json : (text, nat32) -> (Result_32) query;
  read_database_archive_chunk : (text, nat64, nat32) -> (Result_33) query;
  read_node : (text, text) -> (Result_34) query;
  read_node_context : (NodeContextRequest) -> (Result_35) query;
  rename_database : (RenameDatabaseRequest) -> (Result_1);
  revoke_database_access : (text, text) -> (Result_1);
  search_node_paths : (SearchNodePathsRequest) -> (Result_36) query;
  search_nodes : (SearchNodesRequest) -> (Result_36) query;
  settle_database_storage_charges_batch : (StorageBillingBatchRequest) -> (
      Result_37,
    );
  source_evidence : (SourceEvidenceRequest) -> (Result_38) query;
  status : (text) -> (Status) query;
  update_cycles_billing_config : (CyclesBillingConfigUpdate) -> (Result_1);
  wiki_metrics : () -> (Result_39) query;
  write_database_restore_chunk : (DatabaseRestoreChunkRequest) -> (Result_1);
  write_node : (WriteNodeRequest) -> (Result);
  write_nodes : (WriteNodesRequest) -> (Result_40);
  write_source_for_generation : (WriteSourceForGenerationRequest) -> (
      Result_41,
    );
}
