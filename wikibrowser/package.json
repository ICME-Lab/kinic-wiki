{
  "name": "wikibrowser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build && node scripts/normalize-typegen-tsconfig.mjs",
    "lint": "eslint .",
    "smoke": "node scripts/smoke-ui.mjs",
    "smoke:mobile": "node scripts/smoke-mobile-layout.mjs",
    "smoke:errors": "node scripts/smoke-errors.mjs",
    "smoke:public": "node scripts/smoke-public.mjs",
    "generate:vfs-idl": "node scripts/generate-vfs-idl.mjs",
    "test": "node scripts/generate-vfs-idl.mjs --check && node scripts/check-candid-drift.mjs && node scripts/check-paths.mjs && node scripts/check-ui-helpers.mjs && node scripts/check-api-errors.mjs && node scripts/check-auth.mjs && node scripts/check-smoke-url.mjs && node scripts/check-dashboard.mjs && node scripts/check-cycles.mjs && node scripts/check-cycles-wallet.mjs && node scripts/check-marketplace.mjs && node scripts/check-profile.mjs && node scripts/check-skill-registry.mjs && node scripts/check-url-security.mjs",
    "typecheck": "next typegen && node scripts/normalize-typegen-tsconfig.mjs && tsc --noEmit",
    "audit:moderate": "pnpm audit --audit-level moderate",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy --minify",
    "deploy:production": "NEXT_PUBLIC_WIKI_IC_HOST=https://icp0.io NEXT_PUBLIC_KINIC_WIKI_CANISTER_ID=6emaw-iyaaa-aaaay-aacka-cai NEXT_PUBLIC_ENABLE_LOCAL_II_E2E= NEXT_PUBLIC_II_PROVIDER_URL= opennextjs-cloudflare build && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "e2e:ii": "scripts/run-ii-e2e.sh",
    "e2e:ii:headed": "scripts/run-ii-e2e.sh --headed",
    "e2e:ii:setup": "../scripts/setup-wikibrowser-ii-e2e.sh"
  },
